# Gemini API配置
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 智能体配置（可选，使用默认值）
# VITE_AGENT_NAME=经济学考研AI导师
# VITE_AGENT_MODEL=gemini-1.5-pro
# VITE_AGENT_TEMPERATURE=0.7

# 功能开关（可选）
# VITE_FEATURE_QUESTION_GENERATION=true
# VITE_FEATURE_ANSWER_EVALUATION=true
# VITE_FEATURE_SIMILAR_QUESTIONS=true
# VITE_FEATURE_CHAT=true

# 缓存配置（可选）
# VITE_CACHE_ENABLED=true
# VITE_CACHE_MAX_SIZE=100
